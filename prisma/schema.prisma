generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ScanResult {
  id        Int      @id @default(autoincrement())
  siteUrl   String
  imageUrl  String
  result    String
  createdAt DateTime @default(now())
}